{
  "name": "MyAreaSurveyor",
  "displayName": "MyArea Surveyor",
  "version": "1.0.0",
  "description": "Surveyor mobile app for conducting surveys",
  "projectId": "com.myarea.surveyor",
  "bundleId": "com.myarea.surveyor",
  "packageName": "com.myarea.surveyor",
  "android": {
    "versionCode": 1,
    "versionName": "1.0.0",
    "compileSdkVersion": 34,
    "targetSdkVersion": 34,
    "minSdkVersion": 21,
    "permissions": [
      "INTERNET",
      "ACCESS_NETWORK_STATE",
      "ACCESS_FINE_LOCATION",
      "ACCESS_COARSE_LOCATION"
    ]
  },
  "ios": {
    "version": "1.0.0",
    "deploymentTarget": "13.0",
    "permissions": [
      "NSLocationWhenInUseUsageDescription",
      "NSCameraUsageDescription",
      "NSPhotoLibraryUsageDescription"
    ]
  },
  "build": {
    "gradleVersion": "8.0"
  }
}

##############################################################################
#
#   Gradle start up script for POSIX generated by Gradle.
#
#   Important for running:
#
#   (1) You need a POSIX-compliant shell to run this script. If your /bin/sh is
#       noncompliant, but you have some other compliant shell such as bash or ksh,
#       you may want to invoke it via something like:
#
#        bash Gradle
#
#   (2) The slightest misconfiguration of this script will cause your whole
#       system to fail!  Take care in that you do understand what you are doing.
#
##############################################################################

# Attempt to set APP_HOME
# Resolve links: $0 may be a link
app_path=$0

# Need this for daisy-chained symlinks.
while
    APP_HOME=${app_path%"${app_path##*/}"}
    [ -h "$app_path" ]
do
    app_path=$(expr "$app_path" : "$app_path"'$')
done

APP_HOME=$(cd "${APP_HOME:-./}" && pwd -P) || exit

APP_NAME="Gradle"
APP_JAR="gradle-wrapper.jar"

CLASSPATH=$APP_HOME/gradle/wrapper/$APP_JAR

exec "$JAVACMD" "$@"
